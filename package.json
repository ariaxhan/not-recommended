{
  "name": "not-recommended",
  "version": "0.1.0",
  "private": true,
  "description": "A question-first, non-personalized YouTube extension.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ariaxhan/not-recommended.git"
  },
  "keywords": [
    "chrome-extension",
    "youtube",
    "manifest-v3",
    "privacy",
    "non-personalized",
    "recommendations",
    "wikipedia"
  ],
  "scripts": {
    "test": "node --test",
    "lint": "node scripts/check.mjs",
    "verify": "npm run test && npm run lint",
    "package": "node scripts/package.mjs",
    "site:dev": "wrangler dev",
    "site:check": "wrangler deploy --dry-run",
    "site:deploy": "wrangler deploy"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "wrangler": "^4.111.0"
  }
}
